# SOULDAWN Web (Next.js) — Environment Variables
# Скопируй в .env.local и заполни. НИКОГДА не коммить реальные значения.

# ═══════════════════ REQUIRED ═══════════════════

# Токен бота от @BotFather. ОБА имени указывают на один и тот же токен.
# BOT_TOKEN — используется ботом, TELEGRAM_BOT_TOKEN — сайтом.
BOT_TOKEN=
TELEGRAM_BOT_TOKEN=  # можно оставить пустым — сайт возьмёт BOT_TOKEN

# Секрет JWT-сессий сайта. Сгенерируй: openssl rand -base64 32
JWT_SECRET=

# ═══════════════════ DATABASE ═══════════════════
DATABASE_URL=

# ═══════════════════ TELEGRAM ═══════════════════
# Username бота БЕЗ @ (для Login Widget на сайте).
# ВАЖНО: этот же бот должен быть привязан к домену сайта через @BotFather → /setdomain.
NEXT_PUBLIC_TELEGRAM_BOT_NAME=

# ═══════════════════ SITE ═══════════════════
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ═══════════════════ YOOKASSA ═══════════════════
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=

# ═══════════════════ ADMINS ═══════════════════
# Telegram user id через запятую — этим юзерам выдаётся роль admin.
ADMIN_IDS=

# ═══════════════════ ОТЗЫВЫ ═══════════════════
# @username публичной Telegram-группы отзывов (без @)
REVIEW_CHANNEL_USERNAME=
# Прямая ссылка на группу (для кнопки в боте)
REVIEW_CHANNEL_URL=

# ═══════════════════ БОТ ПОДДЕРЖКИ ═══════════════════
# Токен отдельного бота поддержки (@souldawn_support_bot)
SUPPORT_BOT_TOKEN=
# Секрет для защиты webhook-эндпоинтов
WEBHOOK_SECRET=

# ═══════════════════ OPTIONAL ═══════════════════
APPLE_CLIENT_ID=
VK_CLIENT_ID=
VK_CLIENT_SECRET=
NODE_ENV=development
