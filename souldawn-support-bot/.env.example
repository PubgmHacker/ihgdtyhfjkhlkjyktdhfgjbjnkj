# SOULDAWN Bot — Environment Variables
# Copy to .env and fill in values

# ═══════════════════ REQUIRED ═══════════════════
BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# ═══════════════════ TELEGRAM LOGIN WIDGET ═══════════════════
# Used for website JWT auth (same token as BOT_TOKEN)
TG_LOGIN_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ

# ═══════════════════ AI (optional) ═══════════════════
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

# ═══════════════════ YOOKASSA PAYMENT (optional) ═══════════════════
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=https://t.me/souldawn_support_bot

# ═══════════════════ SERVER ═══════════════════
WEBHOOK_PORT=8080
WEBHOOK_SECRET=souldawn-yookassa-secret-2026
SITE_URL=https://souldawn-production.up.railway.app

# ═══════════════════ DATABASE ═══════════════════
# Auto-set by Railway if you add a PostgreSQL plugin.
# Bot auto-converts postgres:// to postgresql+asyncpg://
DATABASE_URL=

# ═══════════════════ ADMINS ═══════════════════
# Comma-separated Telegram user IDs
ADMIN_IDS=8735560311,520904288,1195137911

# ═══════════════════ MINIAPP ═══════════════════
MINIAPP_URL=https://pubgmhacker.github.io/souldawn-support-bot/miniapp/
