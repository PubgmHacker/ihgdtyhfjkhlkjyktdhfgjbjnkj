# SOULDAWN Web (Next.js) — Environment Variables
# Скопируй в .env.local и заполни. НИКОГДА не коммить реальные значения.

# ═══════════════════ REQUIRED ═══════════════════

# Токен бота от @BotFather (тот же, что и у bot/). Нужен для верификации Telegram auth.
TELEGRAM_BOT_TOKEN=

# Секрет JWT-сессий сайта. Сгенерируй: openssl rand -base64 32
JWT_SECRET=

# ═══════════════════ DATABASE ═══════════════════
# Postgres. Railway проставляет автоматически. Prisma работает с postgresql:// напрямую.
DATABASE_URL=

# ═══════════════════ TELEGRAM ═══════════════════
# Username бота БЕЗ @ (для Login Widget). Настрой в BotFather: /setdomain + @username бота.
NEXT_PUBLIC_TELEGRAM_BOT_NAME=

# ═══════════════════ SITE ═══════════════════
# Публичный URL сайта (для webhook, CORS, redirect). Например https://souldawn.example.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ═══════════════════ YOOKASSA PAYMENT (optional) ═══════════════════
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=

# ═══════════════════ APPLE SIGN-IN (optional) ═══════════════════
# Service ID (client_id) из Apple Developer.
APPLE_CLIENT_ID=

# ═══════════════════ VK OAUTH (optional) ═══════════════════
VK_CLIENT_ID=
VK_CLIENT_SECRET=

# ═══════════════════ ADMINS ═══════════════════
# Telegram user id через запятую — этим юзерам выдаётся роль admin.
ADMIN_IDS=

# ═══════════════════ OPTIONAL ═══════════════════
NODE_ENV=development
